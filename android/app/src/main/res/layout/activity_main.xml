<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/claude_orange"
        android:title="@string/app_name"
        android:titleTextColor="#FFFFFF" />

    <LinearLayout
        android:id="@+id/bannerAccessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/warning_bg"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/bannerAccessibilityTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/banner_accessibility_title"
            android:textColor="@color/warning_text"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/banner_accessibility_body"
            android:textColor="@color/warning_text" />

        <Button
            android:id="@+id/bannerAccessibilityAction"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="@string/banner_action_enable" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bannerAlarm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/warning_bg"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/banner_alarm_title"
            android:textColor="@color/warning_text"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/banner_alarm_body"
            android:textColor="@color/warning_text" />

        <Button
            android:id="@+id/bannerAlarmAction"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="@string/banner_action_enable" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#11000000"
        android:padding="8dp"
        android:text="@string/warning_fragile"
        android:textSize="12sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSchedules"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="88dp" />

        <TextView
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/empty_state"
            android:textAlignment="center"
            android:visibility="gone" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="24dp"
            android:backgroundTint="@color/claude_orange"
            android:contentDescription="@string/action_new_schedule"
            android:src="@android:drawable/ic_input_add"
            app:tint="#FFFFFF" />
    </FrameLayout>
</LinearLayout>
